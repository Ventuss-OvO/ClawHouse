{
  "id": "clawhouse",
  "name": "ClawHouse",
  "version": "0.1.0",
  "description": "Connect ClawHouse iOS app as a Gateway channel",
  "configSchema": {
    "type": "object",
    "properties": {
      "pairingToken": {
        "type": "string",
        "description": "Token generated by the iOS app for pairing"
      },
      "relay": {
        "type": "object",
        "description": "Relay service configuration for zero-config connectivity",
        "properties": {
          "url": {
            "type": "string",
            "description": "Relay WebSocket URL (e.g., wss://relay.clawhouse.dev/gateway/connect)"
          },
          "token": {
            "type": "string",
            "description": "Relay token obtained from device registration"
          }
        },
        "required": ["url", "token"]
      },
      "apns": {
        "type": "object",
        "description": "APNs configuration for push notifications",
        "properties": {
          "keyId": {
            "type": "string",
            "description": "APNs auth key ID (10-char identifier from Apple Developer)"
          },
          "teamId": {
            "type": "string",
            "description": "Apple Developer Team ID"
          },
          "keyPath": {
            "type": "string",
            "description": "Path to the .p8 APNs auth key file"
          }
        },
        "required": ["keyId", "teamId", "keyPath"]
      }
    }
  },
  "uiHints": {
    "pairingToken": {
      "label": "Pairing Token",
      "sensitive": true
    },
    "relay.url": {
      "label": "Relay URL"
    },
    "relay.token": {
      "label": "Relay Token",
      "sensitive": true
    },
    "apns.keyPath": {
      "label": "APNs Key File Path"
    }
  }
}
