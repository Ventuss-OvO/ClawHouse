{
  "id": "clawhouse",
  "name": "ClawHouse",
  "version": "0.1.0",
  "description": "Connect ClawHouse iOS app as a Gateway channel",
  "configSchema": {
    "type": "object",
    "properties": {
      "pairingToken": {
        "type": "string",
        "description": "Token generated by the iOS app for pairing"
      },
      "apns": {
        "type": "object",
        "description": "APNs configuration for push notifications",
        "properties": {
          "keyId": {
            "type": "string",
            "description": "APNs auth key ID (10-char identifier from Apple Developer)"
          },
          "teamId": {
            "type": "string",
            "description": "Apple Developer Team ID"
          },
          "keyPath": {
            "type": "string",
            "description": "Path to the .p8 APNs auth key file"
          }
        },
        "required": ["keyId", "teamId", "keyPath"]
      }
    }
  },
  "uiHints": {
    "pairingToken": {
      "label": "Pairing Token",
      "sensitive": true
    },
    "apns.keyPath": {
      "label": "APNs Key File Path"
    }
  }
}
