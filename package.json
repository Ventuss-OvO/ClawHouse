{
  "name": "openclaw-plugin-clawhouse",
  "version": "0.1.0",
  "description": "OpenClaw plugin that enables ClawHouse iOS app to connect as a Gateway channel",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "openclaw",
    "plugin",
    "ios",
    "clawhouse"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "10.0.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "8.56.1",
    "vitest": "^2.0.0"
  }
}
